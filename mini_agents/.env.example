# OpenAI cloud (optional if you use Ollama locally)
OPENAI_API_KEY=sk-your-key-here

# Ollama: OpenAI-compatible API (default below works with `ollama serve`)
OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# Default chat model (all roles unless overridden below). Must match `ollama list` / API id.
LLM_MODEL=qwen2.5:7b

# Optional: different model per agent (same API as OPENAI_BASE_URL)
# LLM_MODEL_PLANNER=qwen2.5:3b
# LLM_MODEL_EXECUTOR=qwen2.5:7b
# LLM_MODEL_CRITIC=qwen2.5:3b
# LLM_MODEL_FINAL=qwen2.5:7b

# Critic step (between executor and final). Set to 0 to skip.
ENABLE_CRITIC=1

# Final synthesis step (uses plan + draft + critic). Set to 0 to stop after executor/critic.
ENABLE_FINAL=1

# Ollama device hint for requests: auto | cpu | gpu
OLLAMA_DEVICE=auto
